---
import type { ReadKind } from '../data/read-kinds';
import { DEFAULT_READ_SHELF, type ReadShelf } from '../data/read-shelves';
import type { BrowseActive, TopicBrowseItem } from '../utils/reads-browse';
import { normalizeReadsPathname, readsPathShelf, readsShelfPath, withReadsBrowseQuery } from '../utils/reads-links';

type Props = {
    /** Current page path (e.g. `Astro.url.pathname`) — format/topic links preserve `?kind=` / `?shelf=` on this path. */
    pathname: string;
    /** Kinds that exist in the reads on this shelf (or filtered list); use `kindsFromReads(...)`. */
    presentKinds: ReadKind[];
    topics: TopicBrowseItem[];
    active: BrowseActive;
    /** Max topic chips before linking to the full topic index */
    topicLimit?: number;
    /** Scope links so the correct shelf tab stays selected after navigation. */
    shelf?: ReadShelf;
    /** Current `?kind=` from the request URL (when set, topic links preserve it). */
    urlKind?: ReadKind;
    /** Current `?shelf=` from the request URL — used when clearing topic from `/reads/topic/…` pages. */
    urlShelf?: ReadShelf;
};

const { pathname, presentKinds, topics, active, topicLimit = 18, shelf, urlKind, urlShelf } = Astro.props;
const path = normalizeReadsPathname(pathname);
const onShelfPath = readsPathShelf(path) !== undefined;
const shownTopics = topics.slice(0, topicLimit);

function topicActive(slug: string): boolean {
    return active.type === 'topic' && active.slug === slug;
}

const kindInQuery = urlKind !== undefined ? { kind: urlKind } : {};

/** Keeps `<details>` open on first paint when this strip reflects an active filter (topic pages, SSR shelf with `?kind=`). */
const filtersInitiallyOpen = active.type === 'topic' || urlKind !== undefined;

function topicChipHref(t: TopicBrowseItem): string {
    if (onShelfPath) {
        if (topicActive(t.slug)) {
            return withReadsBrowseQuery(path, kindInQuery);
        }
        return withReadsBrowseQuery(path, { ...kindInQuery, topic: t.slug });
    }
    if (topicActive(t.slug)) {
        const sh = urlShelf ?? DEFAULT_READ_SHELF;
        return withReadsBrowseQuery(readsShelfPath(sh), kindInQuery);
    }
    return withReadsBrowseQuery(`/reads/topic/${t.slug}/`, {
        ...(shelf !== undefined ? { shelf } : {}),
        ...kindInQuery
    });
}

function topicChipTitle(t: TopicBrowseItem): string {
    const base = `${t.label} (${t.count})`;
    return topicActive(t.slug) ? `Clear topic — ${base}` : base;
}
---

<details
    class="reads-browse-filters border border-main/15 mb-10 sm:mb-12 transition-[border-color] duration-300 hover:border-main/25 open:border-accent/25 px-3 py-2 sm:px-5 sm:py-3"
    open={filtersInitiallyOpen || undefined}
>
    <summary
        class="cursor-pointer select-none list-none flex items-center gap-2 font-mono text-xs text-muted hover:text-main py-2.5 px-1 sm:px-0 -mx-0.5 transition-colors duration-200 [&::-webkit-details-marker]:hidden"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            class="w-3.5 h-3.5 shrink-0 text-main/50"
            aria-hidden="true"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"
            ></path>
        </svg>
        <span>Format &amp; topics</span>
    </summary>
    <div class="pt-4 pb-2 sm:pt-5 sm:pb-3 mt-3 space-y-8 border-t border-main/10">
        <div>
            <p class="font-mono text-[0.65rem] uppercase tracking-wider text-muted/70 mb-3">Format</p>
            <div class="flex flex-wrap gap-2">
                <a
                    href={shelf !== undefined ? withReadsBrowseQuery(path, { shelf }) : withReadsBrowseQuery(path, {})}
                    data-kind-tab=""
                    class:list={[
                        'font-mono text-xs px-1.5 py-0.5 leading-tight border transition-colors duration-200',
                        'border-main/10 text-muted hover:text-main hover:border-main/20',
                        'aria-[current=page]:border-main/25 aria-[current=page]:bg-muted aria-[current=page]:text-main'
                    ]}
                >
                    All
                </a>
                {
                    presentKinds.map((k: ReadKind) => (
                        <a
                            href={
                                shelf !== undefined
                                    ? withReadsBrowseQuery(path, { shelf, kind: k })
                                    : withReadsBrowseQuery(path, { kind: k })
                            }
                            data-kind-tab={k}
                            class:list={[
                                'font-mono text-xs px-1.5 py-0.5 leading-tight border transition-colors duration-200',
                                'border-main/10 text-muted hover:text-main hover:border-main/20',
                                'aria-[current=page]:border-main/25 aria-[current=page]:bg-muted aria-[current=page]:text-main'
                            ]}
                        >
                            {k}
                        </a>
                    ))
                }
            </div>
        </div>

        {
            topics.length > 0 && (
                <div>
                    <div class="flex items-baseline justify-between gap-4 mb-3">
                        <p class="font-mono text-[0.65rem] uppercase tracking-wider text-muted/70">Topics</p>
                        <a
                            href={shelf !== undefined ? `/reads/topics/${shelf}/` : '/reads/topics/'}
                            data-topics-index-link=""
                            class="font-mono text-[0.65rem] text-muted hover:text-main transition-colors duration-200"
                        >
                            View all
                        </a>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {shownTopics.map((t) => (
                            <a
                                href={topicChipHref(t)}
                                data-topic-slug={t.slug}
                                class:list={[
                                    'font-mono text-xs px-1.5 py-0.5 leading-tight border transition-colors duration-200 max-w-[14rem] truncate',
                                    topicActive(t.slug)
                                        ? 'border-main/25 bg-muted text-main'
                                        : 'border-main/10 text-muted hover:text-main hover:border-main/20'
                                ]}
                                title={topicChipTitle(t)}
                            >
                                {t.label}
                                <span class="text-muted/50 tabular-nums">({t.count})</span>
                            </a>
                        ))}
                    </div>
                </div>
            )
        }
    </div>
</details>
