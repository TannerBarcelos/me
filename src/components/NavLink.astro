---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

const { pathname } = Astro.url;
const pathNorm = pathname.replace(/\/$/, '') || '/';
const hrefStr = href != null ? String(href) : '';
const isExternal = hrefStr.startsWith('http');

/** Path only — query/hash break active matching (e.g. Bookshelf is /reads with any ?shelf=&kind=). */
let hrefPathOnly = hrefStr;
if (!isExternal && hrefStr) {
    try {
        hrefPathOnly = new URL(hrefStr, 'https://nav-link.invalid').pathname;
    } catch {
        hrefPathOnly = hrefStr.split('?')[0].split('#')[0];
    }
}
const hrefNorm = hrefPathOnly.replace(/\/$/, '') || '/';

let isActive = false;
if (isExternal) {
    isActive = false;
} else if (hrefNorm === '/') {
    isActive = pathNorm === '/';
} else {
    isActive = pathNorm === hrefNorm || pathNorm.startsWith(`${hrefNorm}/`);
}
---

<a
    class:list={[className, { 'text-main! bg-muted': isActive }]}
    href={href}
    aria-current={isActive ? 'page' : undefined}
    {...props}
>
    <slot />
</a>
