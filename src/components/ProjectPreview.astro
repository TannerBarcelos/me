---
import { type CollectionEntry } from 'astro:content';
import { projectTagsToBadges } from '../data/project-tags';

type Props = { project: CollectionEntry<'projects'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { project, class: className, headingLevel = 'h2' } = Astro.props;
const { title, description, publishDate, tags } = project.data;
const TitleTag = headingLevel;
const year = publishDate.getFullYear();
const tagBadges = projectTagsToBadges(tags);
---

<a class:list={['group block focus-visible:outline-offset-4', className]} href={`/projects/${project.slug}/`}>
    <article
        class="flex items-start justify-between gap-6 py-5 border-b border-main/15 transition-all duration-300 ease-out group-hover:border-accent/30 sm:group-hover:translate-x-[2px]"
    >
        {/* Left: title + description */}
        <div class="min-w-0 pt-0.5">
            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1.5">
                <TitleTag
                    class="font-sans text-lg sm:text-xl font-medium text-main leading-snug tracking-tight group-hover:opacity-75 transition-opacity duration-200"
                >
                    {title}
                </TitleTag>
                {
                    tagBadges.length > 0 && (
                        <div class="flex flex-wrap items-center gap-1.5">
                            {tagBadges.map((t) => <span class:list={['font-mono text-xs px-1.5 py-0.5 leading-tight', t.classes]}>{t.label}</span>)}
                        </div>
                    )
                }
            </div>
            {
                description && (
                    <p class="mt-1.5 text-sm text-muted leading-relaxed line-clamp-2">{description}</p>
                )
            }
        </div>

        {/* Right: year */}
        <div class="flex flex-col items-end shrink-0 pt-0.5">
            <span class="font-mono text-xs text-muted/60 tabular-nums">{year}</span>
        </div>
    </article>
</a>
