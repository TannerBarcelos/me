---
import { type CollectionEntry } from 'astro:content';

type Props = { project: CollectionEntry<'projects'>; class?: string; headingLevel?: 'h2' | 'h3' };

const { project, class: className, headingLevel = 'h2' } = Astro.props;
const { title, description, publishDate } = project.data;
const TitleTag = headingLevel;
const year = publishDate.getFullYear();
---

<a class:list={['group block', className]} href={`/projects/${project.slug}/`}>
    <article class="flex items-baseline justify-between gap-6 py-5 border-b border-main/15 transition-colors duration-200 group-hover:border-main/40">
        <div class="min-w-0">
            <TitleTag
                class="font-sans text-lg sm:text-xl font-medium text-main leading-snug tracking-tight group-hover:opacity-80 transition-opacity duration-200"
            >
                {title}
            </TitleTag>
            {
                description && (
                    <p class="mt-1.5 text-sm text-muted leading-relaxed line-clamp-2">{description}</p>
                )
            }
        </div>
        <span class="font-mono text-xs text-muted/60 shrink-0 tabular-nums">{year}</span>
    </article>
</a>
