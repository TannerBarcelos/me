---
import siteConfig from '../data/site-config';

const socialLinks = siteConfig.socialLinks || [];
const navLinks = siteConfig.footerNavLinks || [];
---

<footer class="w-full max-w-3xl mx-auto pt-16 pb-10 sm:pt-24 sm:pb-14 border-t border-main/20 mt-16 sm:mt-24">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
        {/* Left: nav + social */}
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
            {
                navLinks.map((link) => (
                    <a
                        class="font-mono text-xs text-muted hover:text-main transition-colors duration-200"
                        href={link.href}
                    >
                        {link.text}
                    </a>
                ))
            }
            {
                socialLinks.map((link) => (
                    <a
                        class="font-mono text-xs text-muted hover:text-main transition-colors duration-200"
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {link.text} <span class="opacity-40">↗</span>
                    </a>
                ))
            }
        </div>

        {/* Right: copyright */}
        <p class="font-mono text-xs text-muted/60 shrink-0">
            &copy; {new Date().getFullYear()} Tanner Barcelos
        </p>
    </div>
</footer>
