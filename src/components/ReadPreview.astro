---
import { type CollectionEntry } from 'astro:content';
import { readKindToBadge } from '../data/read-kinds';
import { readProgressToBadge } from '../data/read-progress';

type Props = {
    read: CollectionEntry<'reads'>;
    class?: string;
    headingLevel?: 'h2' | 'h3';
    /** Topic chips under the description (off for home “reading now” strip). */
    showTopicTags?: boolean;
};

const { read, class: className, headingLevel = 'h2', showTopicTags = true } = Astro.props;
const { title, authors, kind, description, topics, publicationYear, addedDate } = read.data;
const TitleTag = headingLevel;
const kindBadge = readKindToBadge(kind);
const progressBadge = readProgressToBadge(read.data.readProgress);
const authorLine = authors.join(', ');
const yearLabel = publicationYear ?? addedDate.getFullYear();
const topicChips = topics.slice(0, 4);
---

<a
    class:list={['read-preview group block', className]}
    href={`/reads/${read.slug}/`}
    data-read-kind={kind}
>
    <article class="flex items-start justify-between gap-6 py-5 border-b border-main/15 transition-colors duration-200 group-hover:border-main/35">
        <div class="min-w-0 pt-0.5">
            <TitleTag
                class="font-sans text-lg sm:text-xl font-medium text-main leading-snug tracking-tight group-hover:opacity-75 transition-opacity duration-200"
            >
                {title}
            </TitleTag>
            <p class="mt-1 text-sm text-muted/90 leading-relaxed">{authorLine}</p>
            {
                description && (
                    <p class="mt-1.5 text-sm text-muted leading-relaxed line-clamp-2">{description}</p>
                )
            }
            {
                showTopicTags && topicChips.length > 0 && (
                    <div class="mt-2 flex flex-wrap gap-1.5">
                        {topicChips.map((t) => (
                            <span class="font-mono text-[0.65rem] uppercase tracking-wide text-muted/70 px-1.5 py-0.5 leading-tight border border-main/15 bg-main/5">
                                {t}
                            </span>
                        ))}
                    </div>
                )
            }
        </div>

        <div class="flex flex-col items-end gap-2 shrink-0 pt-0.5">
            {
                progressBadge && (
                    <span class:list={['font-mono text-xs px-1.5 py-0.5 leading-tight', progressBadge.classes]}>
                        {progressBadge.label}
                    </span>
                )
            }
            <span class:list={['font-mono text-xs px-1.5 py-0.5 leading-tight', kindBadge.classes]}>
                {kindBadge.label}
            </span>
            <span class="font-mono text-xs text-muted/60 tabular-nums">{yearLabel}</span>
        </div>
    </article>
</a>
