---
import { type CollectionEntry } from 'astro:content';
import ReadPreviewRow from './ReadPreviewRow.astro';
import { externalLinkSiteLabel } from '../utils/read-external-label';
import { slugifyTopic } from '../utils/slugify';

type Props = {
    read: CollectionEntry<'reads'>;
    class?: string;
    headingLevel?: 'h2' | 'h3';
    /** Topic chips under the description (off for home “reading now” strip). */
    showTopicTags?: boolean;
};

const { read, class: className, headingLevel = 'h2', showTopicTags = true } = Astro.props;
const { title, authors, kind, description, topics, publicationYear, addedDate, url, readProgress } = read.data;
const topicSlugList = topics.map(slugifyTopic).filter(Boolean).join(' ');
const siteLabel = url ? externalLinkSiteLabel(url) : null;
const overlayLabel = siteLabel ? `View on ${siteLabel}` : null;
const ariaLabel = url ? `${title} — ${overlayLabel} (opens in new tab)` : undefined;

const shellClass =
    'read-preview group relative block focus-visible:outline-offset-4' + (className ? ` ${className}` : '');

const rowProps = {
    title,
    authors,
    kind,
    readProgress,
    description,
    topics,
    publicationYear,
    addedYear: addedDate.getFullYear(),
    headingLevel,
    showTopicTags,
    overlayLabel
};
---

{
    url ? (
        <a
            class:list={[shellClass]}
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={ariaLabel}
            data-read-kind={kind}
            data-read-topic-slugs={topicSlugList}
        >
            <ReadPreviewRow {...rowProps} />
        </a>
    ) : (
        <div class:list={[shellClass]} data-read-kind={kind} data-read-topic-slugs={topicSlugList}>
            <ReadPreviewRow {...rowProps} overlayLabel={null} />
        </div>
    )
}
