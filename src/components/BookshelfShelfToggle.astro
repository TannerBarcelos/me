---
import { READ_KINDS, type ReadKind } from '../data/read-kinds';
import { DEFAULT_READ_SHELF, READ_SHELVES, readShelfTabLabel, type ReadShelf } from '../data/read-shelves';
import { normalizeReadsPathname, readsPathShelf, readsShelfPath, withReadsShelfQuery } from '../utils/reads-links';

type Props = {
    /** Current page path, e.g. `Astro.url.pathname` — used for `?shelf=` tab links. */
    pathname: string;
};

const { pathname } = Astro.props;
const path = normalizeReadsPathname(pathname);
const shelfPathActive = readsPathShelf(path) !== undefined;

const panelRules = READ_SHELVES.map(
    (s: ReadShelf) =>
        `.bookshelf-shelf-toggle[data-bookshelf-root][data-active-shelf="${s}"] .bookshelf-shelf-panel[data-bookshelf-panel="${s}"]{display:block;}`
).join('');

const kindFilterCss = READ_KINDS.map(
    (k: ReadKind) =>
        `[data-bookshelf-read-list][data-active-kind="${k}"] a.read-preview[data-read-kind]:not([data-read-kind="${k}"]){display:none!important;}[data-bookshelf-read-list][data-active-kind="${k}"] div.read-preview[data-read-kind]:not([data-read-kind="${k}"]){display:none!important;}`
).join('');

const topicChipActiveCss = `.bookshelf-shelf-toggle a[data-topic-slug].bookshelf-topic-active{border-color:rgb(var(--color-border-main) / 0.25);background-color:rgb(var(--color-bg-muted));color:rgb(var(--color-text-main) / 1);}`;

const shelfPanelCss = `.bookshelf-shelf-toggle .bookshelf-shelf-panel{display:none;}${panelRules}`;
const combinedCss = shelfPanelCss + kindFilterCss + topicChipActiveCss;
const shelfIdsJson = JSON.stringify([...READ_SHELVES]);
const kindIdsJson = JSON.stringify([...READ_KINDS]);
---

<div class="bookshelf-shelf-toggle" data-bookshelf-root>
    <nav class="mb-8" aria-label="Shelf">
        <div class="flex flex-wrap gap-2">
            {
                READ_SHELVES.map((shelfId: ReadShelf) => (
                    <a
                        href={shelfPathActive ? readsShelfPath(shelfId) : withReadsShelfQuery(path, shelfId)}
                        data-shelf-tab={shelfId}
                        class:list={[
                            'font-mono text-xs px-1.5 py-0.5 leading-tight border transition-colors duration-200',
                            'border-main/10 text-muted hover:text-main hover:border-main/20',
                            'dark:border-main/15 dark:hover:border-main/25',
                            'aria-[current=page]:border-main/25 aria-[current=page]:bg-muted aria-[current=page]:text-main'
                        ]}
                    >
                        {readShelfTabLabel[shelfId]}
                    </a>
                ))
            }
        </div>
    </nav>
    <slot />
    <script is:inline define:vars={{ shelfIdsJson, kindIdsJson, defaultShelf: DEFAULT_READ_SHELF }}>
        (function () {
            var SHELVES = JSON.parse(shelfIdsJson);
            var KINDS = JSON.parse(kindIdsJson);
            function patchShelfTabHrefs() {
                document.querySelectorAll('[data-shelf-tab]').forEach(function (a) {
                    var shelfId = a.getAttribute('data-shelf-tab');
                    var u = new URL(window.location.href);
                    var pathShelfM = u.pathname.match(/^\/reads\/shelf\/(technical|leisure)(\/|$)/);
                    var nu;
                    if (pathShelfM) {
                        nu = new URL('/reads/shelf/' + shelfId + '/', window.location.origin);
                        var kind = u.searchParams.get('kind');
                        var topic = u.searchParams.get('topic');
                        if (kind && KINDS.indexOf(kind) !== -1) nu.searchParams.set('kind', kind);
                        if (topic) nu.searchParams.set('topic', topic);
                    } else {
                        nu = new URL(window.location.href);
                        nu.searchParams.set('shelf', shelfId);
                    }
                    a.setAttribute('href', nu.pathname + nu.search + nu.hash);
                });
            }
            function patchKindTabHrefs() {
                document.querySelectorAll('[data-kind-tab]').forEach(function (a) {
                    var tabKind = a.getAttribute('data-kind-tab');
                    var u = new URL(window.location.href);
                    var nu = new URL(u.href);
                    if (tabKind === '' || tabKind === null) nu.searchParams.delete('kind');
                    else nu.searchParams.set('kind', tabKind);
                    a.setAttribute('href', nu.pathname + nu.search + nu.hash);
                });
            }
            function patchTopicTabHrefs() {
                document.querySelectorAll('[data-topic-slug]').forEach(function (a) {
                    var slug = a.getAttribute('data-topic-slug');
                    if (!slug) return;
                    var u = new URL(window.location.href);
                    var pathShelfM = u.pathname.match(/^\/reads\/shelf\/(technical|leisure)(\/|$)/);
                    var topicPathM = u.pathname.match(/^\/reads\/topic\/([^/]+)(\/|$)/);
                    var nu;
                    var kind = u.searchParams.get('kind');
                    if (pathShelfM) {
                        nu = new URL('/reads/shelf/' + pathShelfM[1] + '/', window.location.origin);
                        var curTopic = u.searchParams.get('topic');
                        if (curTopic && curTopic === slug) {
                            /* active chip: clear topic, keep format filter */
                        } else {
                            nu.searchParams.set('topic', slug);
                        }
                        if (kind && KINDS.indexOf(kind) !== -1) nu.searchParams.set('kind', kind);
                    } else if (topicPathM && topicPathM[1] === slug) {
                        var sh = u.searchParams.get('shelf');
                        var shelfForHome =
                            sh && SHELVES.indexOf(sh) !== -1 ? sh : defaultShelf;
                        nu = new URL('/reads/shelf/' + shelfForHome + '/', window.location.origin);
                        if (kind && KINDS.indexOf(kind) !== -1) nu.searchParams.set('kind', kind);
                    } else {
                        nu = new URL('/reads/topic/' + slug + '/', window.location.origin);
                        var shelf = u.searchParams.get('shelf');
                        if (shelf) nu.searchParams.set('shelf', shelf);
                        if (kind && KINDS.indexOf(kind) !== -1) nu.searchParams.set('kind', kind);
                    }
                    a.setAttribute('href', nu.pathname + nu.search + nu.hash);
                });
            }
            function patchTopicsIndexLink() {
                document.querySelectorAll('[data-topics-index-link]').forEach(function (a) {
                    var u = new URL(window.location.href);
                    var pathShelfM = u.pathname.match(/^\/reads\/shelf\/(technical|leisure)(\/|$)/);
                    var shelf = pathShelfM ? pathShelfM[1] : u.searchParams.get('shelf');
                    var kind = u.searchParams.get('kind');
                    var nu;
                    if (shelf && SHELVES.indexOf(shelf) !== -1) {
                        nu = new URL('/reads/topics/' + shelf + '/', window.location.origin);
                    } else {
                        nu = new URL('/reads/topics/', window.location.origin);
                    }
                    if (kind && KINDS.indexOf(kind) !== -1) nu.searchParams.set('kind', kind);
                    a.setAttribute('href', nu.pathname + nu.search + nu.hash);
                });
            }
            function syncBookshelfFromUrl() {
                try {
                    var roots = document.querySelectorAll('[data-bookshelf-root]');
                    if (roots.length === 0) {
                        var uClean = new URL(window.location.href);
                        if (uClean.searchParams.has('shelf') || uClean.searchParams.has('kind')) {
                            uClean.searchParams.delete('shelf');
                            uClean.searchParams.delete('kind');
                            history.replaceState(null, '', uClean.pathname + uClean.search + uClean.hash);
                        }
                        return;
                    }

                    var u = new URL(window.location.href);
                    var pathShelfM = u.pathname.match(/^\/reads\/shelf\/(technical|leisure)(\/|$)/);
                    var pathShelf = pathShelfM && SHELVES.indexOf(pathShelfM[1]) !== -1 ? pathShelfM[1] : null;
                    var rawShelf = u.searchParams.get('shelf');
                    var s;
                    if (pathShelf) {
                        s = pathShelf;
                    } else if (rawShelf && SHELVES.indexOf(rawShelf) !== -1) {
                        s = rawShelf;
                    } else {
                        s = defaultShelf;
                    }
                    var changed = false;
                    if (pathShelf) {
                        if (u.searchParams.has('shelf')) {
                            u.searchParams.delete('shelf');
                            changed = true;
                        }
                    } else {
                        if (!u.searchParams.has('shelf') || SHELVES.indexOf(rawShelf) === -1) {
                            u.searchParams.set('shelf', s);
                            changed = true;
                        }
                    }
                    var allowedForShelf = [];
                    if (roots.length) {
                        var ap = roots[0].querySelector(
                            '.bookshelf-shelf-panel[data-bookshelf-panel="' + s + '"]'
                        );
                        if (ap) {
                            ap.querySelectorAll('a[data-kind-tab]').forEach(function (a) {
                                var k = a.getAttribute('data-kind-tab');
                                if (k && k !== '') allowedForShelf.push(k);
                            });
                        }
                    }

                    var rawKind = u.searchParams.get('kind');
                    if (rawKind) {
                        if (KINDS.indexOf(rawKind) === -1 || allowedForShelf.indexOf(rawKind) === -1) {
                            u.searchParams.delete('kind');
                            changed = true;
                        }
                    }
                    if (changed) history.replaceState(null, '', u.pathname + u.search + u.hash);

                    var curKind = u.searchParams.get('kind');
                    var curTopic = (u.searchParams.get('topic') || '').trim();
                    var topicPathM = u.pathname.match(/^\/reads\/topic\/([^/]+)/);
                    var keepFiltersExpanded = !!(curKind || curTopic || topicPathM);

                    roots.forEach(function (root) {
                        root.setAttribute('data-active-shelf', s);
                        root.querySelectorAll('[data-shelf-tab]').forEach(function (a) {
                            if (a.getAttribute('data-shelf-tab') === s) a.setAttribute('aria-current', 'page');
                            else a.removeAttribute('aria-current');
                        });

                        root.querySelectorAll('[data-bookshelf-read-list]').forEach(function (el) {
                            var panel = el.closest('[data-bookshelf-panel]');
                            var allowed = [];
                            if (panel) {
                                panel.querySelectorAll('a[data-kind-tab]').forEach(function (a) {
                                    var k = a.getAttribute('data-kind-tab');
                                    if (k && k !== '') allowed.push(k);
                                });
                            }
                            var effective =
                                curKind && allowed.indexOf(curKind) !== -1 ? curKind : 'all';
                            el.setAttribute('data-active-kind', effective);
                        });

                        root.querySelectorAll('a[data-topic-slug]').forEach(function (a) {
                            var slug = a.getAttribute('data-topic-slug');
                            if (curTopic && slug === curTopic) a.classList.add('bookshelf-topic-active');
                            else a.classList.remove('bookshelf-topic-active');
                        });

                        root.querySelectorAll('[data-bookshelf-read-list]').forEach(function (list) {
                            list.querySelectorAll('.read-preview').forEach(function (card) {
                                var raw = card.getAttribute('data-read-topic-slugs') || '';
                                var slugs = raw.split(/\s+/).filter(Boolean);
                                if (!curTopic) {
                                    card.style.removeProperty('display');
                                } else if (slugs.indexOf(curTopic) !== -1) {
                                    card.style.removeProperty('display');
                                } else {
                                    card.style.setProperty('display', 'none', 'important');
                                }
                            });
                        });

                        root.querySelectorAll('.bookshelf-shelf-panel').forEach(function (panel) {
                            var pid = panel.getAttribute('data-bookshelf-panel');
                            var isActivePanel = pid === s;
                            panel.querySelectorAll('a[data-kind-tab]').forEach(function (a) {
                                if (!isActivePanel) {
                                    a.removeAttribute('aria-current');
                                    return;
                                }
                                var tabKind = a.getAttribute('data-kind-tab');
                                var isAll = !curKind || curKind === '';
                                if ((tabKind === '' || tabKind === null) && isAll)
                                    a.setAttribute('aria-current', 'page');
                                else if (tabKind === curKind) a.setAttribute('aria-current', 'page');
                                else a.removeAttribute('aria-current');
                            });
                        });

                        if (keepFiltersExpanded) {
                            root.querySelectorAll('details.reads-browse-filters').forEach(function (d) {
                                d.open = true;
                            });
                        }
                    });

                    patchShelfTabHrefs();
                    patchKindTabHrefs();
                    patchTopicTabHrefs();
                    patchTopicsIndexLink();
                } catch (e) {}
            }
            syncBookshelfFromUrl();
            if (!window.__bookshelfShelfPageLoadBound) {
                window.__bookshelfShelfPageLoadBound = true;
                document.addEventListener('astro:page-load', syncBookshelfFromUrl);
            }
        })();
    </script>
</div>

<Fragment set:html={`<style>${combinedCss}</style>`} />
