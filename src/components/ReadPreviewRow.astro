---
import { readKindToBadge } from '../data/read-kinds';
import { readProgressToBadge } from '../data/read-progress';
import type { ReadKind } from '../data/read-kinds';
import type { ReadProgress } from '../data/read-progress';

type Props = {
    title: string;
    authors: string[];
    kind: ReadKind;
    readProgress?: ReadProgress;
    description?: string;
    topics: string[];
    publicationYear?: number;
    addedYear: number;
    headingLevel: 'h2' | 'h3';
    showTopicTags: boolean;
    /** Shown on hover/focus overlay; omit for no overlay. */
    overlayLabel?: string | null;
    /** Hide read-progress + kind badges below `sm`; year stays visible. */
    hideMetaBadgesOnMobile?: boolean;
};

const {
    title,
    authors,
    kind,
    readProgress,
    description,
    topics,
    publicationYear,
    addedYear,
    headingLevel,
    showTopicTags,
    overlayLabel,
    hideMetaBadgesOnMobile = false
} = Astro.props;

const TitleTag = headingLevel;
const kindBadge = readKindToBadge(kind);
const progressBadge = readProgressToBadge(readProgress);
const authorLine = authors.join(', ');
const yearLabel = publicationYear ?? addedYear;
const topicChips = topics.slice(0, 4);
---

<article
    class:list={[
        'relative z-0 flex items-start justify-between gap-6 py-5 border-b border-main/15 transition-all duration-300 ease-out',
        overlayLabel &&
            'group-hover:border-accent/30 sm:group-hover:translate-x-[2px]'
    ]}
>
    <div class="min-w-0 pt-0.5">
        <TitleTag
            class:list={[
                'font-sans text-lg sm:text-xl font-medium text-main leading-snug tracking-tight',
                overlayLabel && 'group-hover:opacity-75 transition-opacity duration-200'
            ]}
        >
            {title}
        </TitleTag>
        <p class="mt-1 text-sm text-muted/90 leading-relaxed">{authorLine}</p>
        {
            description && (
                <p class="mt-1.5 text-sm text-muted leading-relaxed line-clamp-2">{description}</p>
            )
        }
        {
            showTopicTags && topicChips.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                    {topicChips.map((t) => (
                        <span class="font-mono text-[0.65rem] uppercase tracking-wide text-muted/70 px-1.5 py-0.5 leading-tight border border-main/15 bg-main/[0.04] dark:bg-main/[0.06] dark:border-main/20">
                            {t}
                        </span>
                    ))}
                </div>
            )
        }
    </div>

    <div class="flex flex-col items-end gap-2 shrink-0 pt-0.5">
        <div
            class:list={[
                hideMetaBadgesOnMobile
                    ? 'hidden sm:flex sm:flex-col sm:items-end sm:gap-2'
                    : 'flex flex-col items-end gap-2'
            ]}
        >
            {
                progressBadge && (
                    <span class:list={['font-mono text-xs px-1.5 py-0.5 leading-tight', progressBadge.classes]}>
                        {progressBadge.label}
                    </span>
                )
            }
            <span class:list={['font-mono text-xs px-1.5 py-0.5 leading-tight', kindBadge.classes]}>{kindBadge.label}</span>
        </div>
        <span class="font-mono text-xs text-muted/60 tabular-nums">{yearLabel}</span>
    </div>

    {
        overlayLabel && (
            <div
                class:list={[
                    'pointer-events-none absolute inset-0 z-[1] flex items-center justify-center',
                    'bg-main/[0.76] dark:bg-main/[0.8] backdrop-blur-[1.5px]',
                    'opacity-0 transition-opacity duration-200 ease-out',
                    'motion-reduce:transition-none',
                    '[@media(hover:hover)_and_(pointer:fine)]:group-hover:opacity-100',
                    'group-focus-visible:opacity-100',
                    'group-active:opacity-100'
                ]}
                aria-hidden="true"
            >
                <span class="font-mono text-xs sm:text-sm text-main tracking-wide px-3 inline-flex items-center justify-center gap-1.5 text-center">
                    {overlayLabel}
                    <svg
                        class="w-3.5 h-3.5 shrink-0 text-main/90"
                        viewBox="0 0 12 12"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                        aria-hidden="true"
                    >
                        <path
                            d="M2 10L10 2M10 2H5.5M10 2V6.5"
                            stroke="currentColor"
                            stroke-width="1.25"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        />
                    </svg>
                </span>
            </div>
        )
    }
</article>
