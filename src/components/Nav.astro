---
import NavLink from './NavLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import siteConfig from '../data/site-config';

const navLinks = siteConfig.headerNavLinks || [];
---

<nav class="w-full max-w-3xl mx-auto flex items-center justify-between pt-8 pb-3 md:pb-0 md:pt-12 md:border-b md:border-main/10">
    {/* Site identity — left */}
    <a
        href="/"
        class="font-mono text-sm text-muted hover:text-main transition-colors duration-200 tracking-tight focus-visible:outline-offset-4"
        aria-label="Home"
    >
        <span class="text-main/40 mr-1 select-none">~/</span>tannerbarcelos
    </a>

    {/* Nav links — right (desktop) + mobile toggle */}
    <div class="flex items-center gap-1">
        {
            navLinks.length > 0 && (
                <>
                    {/* Desktop nav */}
                    <ul class="hidden md:flex items-center gap-0.5 mr-3">
                        {navLinks.map((link) => (
                            <li>
                                <NavLink
                                    class="font-mono text-xs text-muted hover:text-main px-2.5 py-1.5 md:border-l-2 md:border-transparent md:pl-2.5 transition-colors duration-200"
                                    href={link.href}
                                    target={link.newTab ? '_blank' : undefined}
                                    rel={link.newTab ? 'noopener noreferrer' : undefined}
                                    aria-label={link.text}
                                >
                                    {link.text}
                                </NavLink>
                            </li>
                        ))}
                    </ul>

                    {/* Mobile hamburger */}
                    <button
                        class="menu-toggle md:hidden w-8 h-8 flex items-center justify-center relative z-30"
                        aria-label="Open Menu"
                        aria-expanded="false"
                        aria-controls="menu-items"
                    >
                        <span class="menu-toggle-icon w-5 h-px relative bg-current" />
                    </button>

                    {/* Mobile menu */}
                    <ul
                        id="menu-items"
                        class="menu md:hidden absolute top-0 left-0 right-0 flex-col gap-0 pt-16 pb-6 px-4 bg-main border-b border-main z-20"
                    >
                        {navLinks.map((link) => (
                            <li>
                                <NavLink
                                    class="font-mono text-sm text-muted hover:text-main flex items-center py-3 border-b border-main/30 transition-colors duration-150"
                                    href={link.href}
                                    target={link.newTab ? '_blank' : undefined}
                                    rel={link.newTab ? 'noopener noreferrer' : undefined}
                                    aria-label={link.text}
                                >
                                    <span class="text-main/30 mr-3 text-xs select-none">//</span>
                                    {link.text}
                                    {link.newTab && <span class="ml-auto text-main/30 text-xs">↗</span>}
                                </NavLink>
                            </li>
                        ))}
                    </ul>
                </>
            )
        }
        <ThemeToggle />
    </div>
</nav>

<style>
    nav {
        position: relative;
    }
    .menu {
        display: none;
    }
    .menu.is-visible {
        display: flex;
    }

    /* Active nav link override */
    :global(.menu a[aria-current='page']),
    :global(ul:not(.menu) a[aria-current='page']) {
        color: rgb(var(--color-text-main));
    }

    /* Desktop active indicator — sharp left rule, no pill */
    @media (min-width: 768px) {
        :global(ul:not(.menu) a[aria-current='page']) {
            background-color: rgb(var(--color-bg-muted) / 0.65);
            border-left-color: rgb(var(--color-accent) / 0.85);
            box-shadow: inset 0 0 0 1px rgb(var(--color-border-main) / 0.35);
        }
    }

    .menu-toggle-icon {
        transition: width 0.1s cubic-bezier(0.4, 0, 0.2, 1) 0.3s;
    }
    .menu-toggle.is-active .menu-toggle-icon {
        width: 0;
        transition: width 0.1s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .menu-toggle-icon:before,
    .menu-toggle-icon:after {
        content: '';
        position: absolute;
        left: 50%;
        top: 0;
        width: 1.25rem;
        height: 1px;
        transform: translateX(-50%);
        background: currentColor;
        transition:
            transform 0.2s cubic-bezier(0.4, 0, 0.2, 1),
            margin 0.2s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;
    }
    .menu-toggle-icon:before {
        margin-top: -5px;
    }
    .menu-toggle-icon:after {
        margin-top: 5px;
    }
    .menu-toggle.is-active .menu-toggle-icon:before,
    .menu-toggle.is-active .menu-toggle-icon:after {
        margin-top: 0;
        transition:
            margin 0.2s cubic-bezier(0.4, 0, 0.2, 1) 0.1s,
            transform 0.2s cubic-bezier(0.4, 0, 0.2, 1) 0.3s;
    }
    .menu-toggle.is-active .menu-toggle-icon:before {
        transform: translateX(-50%) rotate(45deg);
    }
    .menu-toggle.is-active .menu-toggle-icon:after {
        transform: translateX(-50%) rotate(-45deg);
    }
</style>

<script>
    function menuToggle() {
        const menu = document.querySelector('.menu');
        const menuToggleBtn = document.querySelector('.menu-toggle');
        menuToggleBtn?.addEventListener('click', () => {
            const isMenuExpanded = menuToggleBtn.getAttribute('aria-expanded') === 'true';
            menuToggleBtn.classList.toggle('is-active');
            menuToggleBtn.setAttribute('aria-expanded', isMenuExpanded ? 'false' : 'true');
            menuToggleBtn.setAttribute('aria-label', isMenuExpanded ? 'Open Menu' : 'Close Menu');
            menu?.classList.toggle('is-visible');
        });
    }
    menuToggle();
    document.addEventListener('astro:after-swap', menuToggle);
</script>
