---
import Button from './Button.astro';
import siteConfig from '../data/site-config';

const hero = siteConfig.hero;
---

{
    hero?.actions && hero.actions.length > 0 && (
        <section class="w-full pt-20 pb-24 sm:pt-28 sm:pb-32">
            {/* Large name heading with blinking cursor */}
            <h1 class="font-sans text-4xl sm:text-5xl md:text-6xl font-medium tracking-tight text-main leading-[1.1] mb-5">
                Tanner Barcelos<span class="name-cursor" aria-hidden="true" />
            </h1>

            {/* Typed rotating tagline */}
            <div class="font-mono text-sm sm:text-base text-muted mb-12 min-h-[1.5rem]">
                <span id="typed-tagline"></span>
            </div>

            {/* CTA buttons */}
            <div class="flex flex-wrap items-center gap-4">
                {hero.actions.map((action, i) => (
                    <Button href={action.href} target={action.newTab ? '_blank' : '_self'} variant={i === 0 ? 'primary' : 'ghost'}>
                        {action.text}
                    </Button>
                ))}
            </div>
        </section>
    )
}

<style>
    /* Blinking underscore cursor on the name */
    .name-cursor::after {
        content: '_';
        animation: cursor-blink 1.1s step-end infinite;
        margin-left: 1px;
        font-weight: 300;
        opacity: 0.5;
    }

    @keyframes cursor-blink {
        0%, 100% { opacity: 0.5; }
        50%       { opacity: 0; }
    }
</style>

<script>
    import Typed from 'typed.js';

    // Track the active instance so we can destroy before re-init
    let typedInstance: InstanceType<typeof Typed> | null = null;

    function initTyped() {
        const el = document.getElementById('typed-tagline');
        if (!el) return;

        // Destroy any existing instance before creating a new one
        if (typedInstance) {
            typedInstance.destroy();
            typedInstance = null;
        }

        typedInstance = new Typed('#typed-tagline', {
            strings: [
                'building AI/ML platforms',
                'senior ml engineer @ visa',
                'react · typescript · go',
                'distributed systems',
                'ai enthusiast',
                'building developer tooling',
                'silicon valley'
            ],
            typeSpeed: 42,
            backSpeed: 22,
            backDelay: 2200,
            startDelay: 250,
            loop: true,
            cursorChar: '_',
            smartBackspace: false,
            contentType: 'text'
        });
    }

    // Destroy on page swap (before new content loads)
    document.addEventListener('astro:before-swap', () => {
        if (typedInstance) {
            typedInstance.destroy();
            typedInstance = null;
        }
    });

    // Re-init after every page load (covers SPA navigation)
    document.addEventListener('astro:page-load', initTyped);

    // Also init directly — astro:page-load on initial load can race with
    // module script registration depending on ClientRouter timing
    initTyped();
</script>
