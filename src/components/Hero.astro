---
import Button from './Button.astro';
import siteConfig from '../data/site-config';

const hero = siteConfig.hero;
---

<section class="w-full pt-20 pb-24 sm:pt-28 sm:pb-32">
    {/* Large name heading with blinking cursor */}
    <h1
        class="hero-headline font-sans text-4xl sm:text-5xl md:text-6xl font-medium tracking-tight text-main leading-[1.08] mb-6"
    >
        Tanner Barcelos<span class="name-cursor" aria-hidden="true" />
    </h1>

    {/* Typed rotating tagline */}
    <div class="hero-tagline font-mono text-sm sm:text-base text-muted mb-12 min-h-[1.5rem] tracking-tight">
        <span id="typed-tagline" class="text-main/85"></span>
    </div>

    {/* CTA buttons — optional; tagline stays even with no actions */}
    {
        hero?.actions && hero.actions.length > 0 && (
            <div class="hero-actions flex flex-col items-stretch gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-4 [&>*]:w-full [&>*]:sm:w-auto">
                {hero.actions.map((action, i) => (
                    <Button href={action.href} target={action.newTab ? '_blank' : '_self'} variant={i === 0 ? 'primary' : 'ghost'}>
                        {action.text}
                    </Button>
                ))}
            </div>
        )
    }
</section>

<style>
    /* Blinking underscore cursor on the name */
    .name-cursor::after {
        content: '_';
        animation: cursor-blink 1.1s step-end infinite;
        margin-left: 1px;
        font-weight: 300;
        opacity: 0.45;
        color: rgb(var(--color-accent));
    }

    @keyframes cursor-blink {
        0%,
        100% {
            opacity: 0.45;
        }
        50% {
            opacity: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .name-cursor::after {
            animation: none;
            opacity: 0.35;
        }
    }
</style>

<script>
    import Typed from 'typed.js';

    let typedInstance: InstanceType<typeof Typed> | null = null;

    function initTyped() {
        const el = document.getElementById('typed-tagline');
        if (!el) return;

        if (typedInstance) {
            typedInstance.destroy();
            typedInstance = null;
        }

        typedInstance = new Typed('#typed-tagline', {
            strings: [
                'building AI/ML platforms',
                'senior ml engineer @ visa',
                'react · typescript · go',
                'distributed systems',
                'ai enthusiast',
                'building developer tooling',
                'silicon valley'
            ],
            typeSpeed: 42,
            backSpeed: 22,
            backDelay: 2200,
            startDelay: 250,
            loop: true,
            cursorChar: '_',
            smartBackspace: false,
            contentType: 'text'
        });
    }

    document.addEventListener('astro:before-swap', () => {
        if (typedInstance) {
            typedInstance.destroy();
            typedInstance = null;
        }
    });

    document.addEventListener('astro:page-load', initTyped);
    initTyped();
</script>
