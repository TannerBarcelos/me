---
const { page, class: className } = Astro.props;
---

<nav aria-label="Pagination" class:list={['flex items-center justify-between', className]}>
    {
        page.url.prev ? (
            <a
                href={page.url.prev}
                class="font-mono text-xs text-muted hover:text-main transition-colors duration-200"
                aria-label={`Go to page ${page.currentPage - 1} of ${page.lastPage}`}
            >
                ← prev
            </a>
        ) : (
            <span />
        )
    }

    <span class="font-mono text-xs text-muted/60" aria-current="page">
        {page.currentPage} / {page.lastPage}
    </span>

    {
        page.url.next ? (
            <a
                href={page.url.next}
                class="font-mono text-xs text-muted hover:text-main transition-colors duration-200"
                aria-label={`Go to page ${page.currentPage + 1} of ${page.lastPage}`}
            >
                next →
            </a>
        ) : (
            <span />
        )
    }
</nav>
