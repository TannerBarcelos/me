---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectPreview from '../components/ProjectPreview.astro';
import ReadPreview from '../components/ReadPreview.astro';
import siteConfig from '../data/site-config';
import { sortItemsByDateDesc, sortReadsReadingNow } from '../utils/data-utils';

const projects = (await getCollection('projects')).sort(sortItemsByDateDesc);
/** "What I'm building" = projects whose tags include `in-progress` (excludes paused, live-only, etc.). */
const buildingProjects = projects.filter(({ data }) => data.tags.includes('in-progress'));

const reads = await getCollection('reads');
const readingNow = reads.filter(({ data }) => data.readingNow).sort(sortReadsReadingNow);
---

<BaseLayout description={siteConfig.description} showHeader={false}>
    <Hero />

    {
        buildingProjects?.length > 0 && (
            <section class="pb-24 sm:pb-32">
                {/* Section label */}
                <div class="flex items-baseline justify-between mb-8">
                    <p class="font-mono text-xs text-muted select-none">
                        <span class="opacity-50">{'// '}</span>what I'm building
                    </p>
                    <a
                        href="/projects"
                        class="font-mono text-xs text-muted hover:text-main transition-colors duration-200"
                    >
                        view all →
                    </a>
                </div>

                {/* Project list */}
                <div>
                    {buildingProjects.map((project) => (
                        <ProjectPreview project={project} headingLevel="h3" />
                    ))}
                </div>
            </section>
        )
    }

    {
        readingNow?.length > 0 && (
            <section class="pb-24 sm:pb-32">
                <div class="flex items-baseline justify-between mb-8">
                    <p class="font-mono text-xs text-muted select-none">
                        <span class="opacity-50">{'// '}</span>what I'm reading
                    </p>
                    <a
                        href="/reads"
                        class="font-mono text-xs text-muted hover:text-main transition-colors duration-200"
                    >
                        all reads →
                    </a>
                </div>

                <div>
                    {readingNow.map((read) => <ReadPreview read={read} headingLevel="h3" />)}
                </div>
            </section>
        )
    }
</BaseLayout>
