---
import BaseLayout from '../layouts/BaseLayout.astro';
import SimpleIcon from '../components/SimpleIcon.astro';
import type { SimpleIcon } from 'simple-icons';
import {
    siAnthropic,
    siAstro,
    siBun,
    siClaude,
    siCursor,
    siDatadog,
    siDocker,
    siGithubactions,
    siGo,
    siGooglegemini,
    siGrafana,
    siGraphql,
    siHelm,
    siHono,
    siJavascript,
    siKubernetes,
    siLangchain,
    siMongodb,
    siNodedotjs,
    siOpentelemetry,
    siJest,
    siPostgresql,
    siPrometheus,
    siPython,
    siReact,
    siRedis,
    siSocketdotio,
    siSvelte,
    siTailwindcss,
    siTanstack,
    siTerraform,
    siTmux,
    siTypescript,
    siVite,
    siVitest
} from 'simple-icons';

const title = 'Tech stack & AI tools';
const description = 'What I use in production: languages, platforms, and AI tooling.';

const siOpenAI: SimpleIcon = {
    title: 'OpenAI',
    slug: 'openai',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-openai" viewBox="0 0 16 16"><path d="M14.949 6.547a3.94 3.94 0 0 0-.348-3.273 4.11 4.11 0 0 0-4.4-1.934A4.1 4.1 0 0 0 8.423.2 4.15 4.15 0 0 0 6.305.086a4.1 4.1 0 0 0-1.891.948 4.04 4.04 0 0 0-1.158 1.753 4.1 4.1 0 0 0-1.563.679A4 4 0 0 0 .554 4.72a3.99 3.99 0 0 0 .502 4.731 3.94 3.94 0 0 0 .346 3.274 4.11 4.11 0 0 0 4.402 1.933c.382.425.852.764 1.377.995.526.231 1.095.35 1.67.346 1.78.002 3.358-1.132 3.901-2.804a4.1 4.1 0 0 0 1.563-.68 4 4 0 0 0 1.14-1.253 3.99 3.99 0 0 0-.506-4.716m-6.097 8.406a3.05 3.05 0 0 1-1.945-.694l.096-.054 3.23-1.838a.53.53 0 0 0 .265-.455v-4.49l1.366.778q.02.011.025.035v3.722c-.003 1.653-1.361 2.992-3.037 2.996m-6.53-2.75a2.95 2.95 0 0 1-.36-2.01l.095.057L5.29 12.09a.53.53 0 0 0 .527 0l3.949-2.246v1.555a.05.05 0 0 1-.022.041L6.473 13.3c-1.454.826-3.311.335-4.15-1.098m-.85-6.94A3.02 3.02 0 0 1 3.07 3.949v3.785a.51.51 0 0 0 .262.451l3.93 2.237-1.366.779a.05.05 0 0 1-.048 0L2.585 9.342a2.98 2.98 0 0 1-1.113-4.094zm11.216 2.571L8.747 5.576l1.362-.776a.05.05 0 0 1 .048 0l3.265 1.86a3 3 0 0 1 1.173 1.207 2.96 2.96 0 0 1-.27 3.2 3.05 3.05 0 0 1-1.36.997V8.279a.52.52 0 0 0-.276-.445m1.36-2.015-.097-.057-3.226-1.855a.53.53 0 0 0-.53 0L6.249 6.153V4.598a.04.04 0 0 1 .019-.04L9.533 2.7a3.07 3.07 0 0 1 3.257.139c.474.325.843.778 1.066 1.303.223.526.289 1.103.191 1.664zM5.503 8.575 4.139 7.8a.05.05 0 0 1-.026-.037V4.049c0-.57.166-1.127.476-1.607s.752-.864 1.275-1.105a3.08 3.08 0 0 1 3.234.41l-.096.054-3.23 1.838a.53.53 0 0 0-.265.455zm.742-1.577 1.758-1 1.762 1v2l-1.755 1-1.762-1z"/></svg>',
    path: 'M14.949 6.547a3.94 3.94 0 0 0-.348-3.273 4.11 4.11 0 0 0-4.4-1.934A4.1 4.1 0 0 0 8.423.2 4.15 4.15 0 0 0 6.305.086a4.1 4.1 0 0 0-1.891.948 4.04 4.04 0 0 0-1.158 1.753 4.1 4.1 0 0 0-1.563.679A4 4 0 0 0 .554 4.72a3.99 3.99 0 0 0 .502 4.731 3.94 3.94 0 0 0 .346 3.274 4.11 4.11 0 0 0 4.402 1.933c.382.425.852.764 1.377.995.526.231 1.095.35 1.67.346 1.78.002 3.358-1.132 3.901-2.804a4.1 4.1 0 0 0 1.563-.68 4 4 0 0 0 1.14-1.253 3.99 3.99 0 0 0-.506-4.716m-6.097 8.406a3.05 3.05 0 0 1-1.945-.694l.096-.054 3.23-1.838a.53.53 0 0 0 .265-.455v-4.49l1.366.778q.02.011.025.035v3.722c-.003 1.653-1.361 2.992-3.037 2.996m-6.53-2.75a2.95 2.95 0 0 1-.36-2.01l.095.057L5.29 12.09a.53.53 0 0 0 .527 0l3.949-2.246v1.555a.05.05 0 0 1-.022.041L6.473 13.3c-1.454.826-3.311.335-4.15-1.098m-.85-6.94A3.02 3.02 0 0 1 3.07 3.949v3.785a.51.51 0 0 0 .262.451l3.93 2.237-1.366.779a.05.05 0 0 1-.048 0L2.585 9.342a2.98 2.98 0 0 1-1.113-4.094zm11.216 2.571L8.747 5.576l1.362-.776a.05.05 0 0 1 .048 0l3.265 1.86a3 3 0 0 1 1.173 1.207 2.96 2.96 0 0 1-.27 3.2 3.05 3.05 0 0 1-1.36.997V8.279a.52.52 0 0 0-.276-.445m1.36-2.015-.097-.057-3.226-1.855a.53.53 0 0 0-.53 0L6.249 6.153V4.598a.04.04 0 0 1 .019-.04L9.533 2.7a3.07 3.07 0 0 1 3.257.139c.474.325.843.778 1.066 1.303.223.526.289 1.103.191 1.664zM5.503 8.575 4.139 7.8a.05.05 0 0 1-.026-.037V4.049c0-.57.166-1.127.476-1.607s.752-.864 1.275-1.105a3.08 3.08 0 0 1 3.234.41l-.096.054-3.23 1.838a.53.53 0 0 0-.265.455zm.742-1.577 1.758-1 1.762 1v2l-1.755 1-1.762-1z',
    source: 'https://openai.com/brand',
    hex: '000000'
};

const tagBase = 'font-mono text-xs px-1.5 py-0.5 leading-tight border';
const tagNeutral =
    'border-zinc-500/30 bg-zinc-400/[0.05] text-zinc-600 dark:border-zinc-500/25 dark:bg-zinc-400/[0.04] dark:text-zinc-400';
const tagViolet =
    'border-violet-600/35 bg-violet-500/[0.06] text-violet-700 dark:border-violet-400/25 dark:bg-violet-400/[0.05] dark:text-violet-400';
const tagEmerald =
    'border-emerald-600/35 bg-emerald-500/[0.06] text-emerald-700 dark:border-emerald-400/25 dark:bg-emerald-400/[0.05] dark:text-emerald-400';
const tagSky =
    'border-sky-600/35 bg-sky-500/[0.06] text-sky-800 dark:border-sky-400/25 dark:bg-sky-400/[0.06] dark:text-sky-300';

type SoftwareRow = { icon: SimpleIcon[]; label: string; detail?: string };

const software: { id: string; title: string; intro: string; rows: SoftwareRow[] }[] = [
    {
        id: 'languages',
        title: 'Languages',
        intro: 'What I write most often — not the same thing as runtimes or frameworks below.',
        rows: [
            {
                icon: [siTypescript, siJavascript, siGo, siPython],
                label: 'TypeScript · JavaScript · Go · Python',
                detail: 'TypeScript and JavaScript for application code; Go for microservices and control planes; Python for tooling, notebooks, and ML-adjacent glue.'
            }
        ]
    },
    {
        id: 'runtimes',
        title: 'Runtimes',
        intro: 'Where JS/TS executes — distinct from Hono or any web framework.',
        rows: [
            {
                icon: [siBun, siNodedotjs],
                label: 'Bun · Node.js',
                detail: 'Bun is my usual Node-compatible runtime for new JS services and scripts. I still reach for Node.js when tooling, libraries, or deployment targets expect it.'
            }
        ]
    },
    {
        id: 'web-ui',
        title: 'Web UI & client stack',
        intro: 'Product-facing work: frameworks, styling, and build tooling.',
        rows: [
            {
                icon: [siReact, siTanstack, siSvelte, siTailwindcss, siVite, siAstro],
                label: 'React · TanStack Suite · Svelte / SvelteKit · Tailwind CSS · Vite · Astro',
                detail: 'React with the TanStack Suite (Query, Router, and whatever else fits the feature); Svelte and SvelteKit when I want lean reactivity. Tailwind everywhere; Vite for builds; Astro for content sites like this one.'
            }
        ]
    },
    {
        id: 'backend',
        title: 'Backend & APIs',
        intro: 'Services and HTTP boundaries — framework choice is separate from which runtime hosts it.',
        rows: [
            {
                icon: [siGo, siHono, siGraphql, siSocketdotio],
                label: 'Go (Gin, Chi) · Hono · GraphQL federation · REST · WebSockets',
                detail: 'Go for most service logic. Hono is my go-to small web framework for TypeScript HTTP APIs; I usually run it on Bun, but that is a hosting choice — not the same dimension as “what language” or “what framework.” GraphQL (including federation), REST, and WebSockets for APIs and realtime surfaces (dashboards, control planes, live updates).'
            }
        ]
    },
    {
        id: 'platform',
        title: 'Data, infrastructure, observability & ML',
        intro: 'The resume-shaped layer: storage, delivery, signals, tests, and production ML patterns.',
        rows: [
            {
                icon: [siPostgresql, siRedis, siMongodb],
                label: 'PostgreSQL · Redis · MongoDB',
                detail: ''
            },
            {
                icon: [siKubernetes, siDocker, siTerraform, siHelm],
                label: 'Kubernetes · Docker · Terraform · Helm',
                detail: 'Multi-cluster and resilient deployments; GitOps and infra-as-code.'
            },
            {
                icon: [siGithubactions],
                label: 'GitHub Actions',
                detail: 'CI/CD pipelines and release automation.'
            },
            {
                icon: [siDatadog, siPrometheus, siGrafana, siOpentelemetry],
                label: 'Datadog · Prometheus · Grafana · OpenTelemetry',
                detail: 'Metrics, traces, and dashboards aligned with on-call reality.'
            },
            {
                icon: [siVitest, siJest],
                label: 'Playwright · Vitest · Jest · React Testing Library',
                detail: ''
            },
            {
                icon: [siLangchain],
                label: 'LangChain · prompt engineering · model APIs',
                detail: 'Plus evaluation and guardrail patterns for control planes in front of real models and traffic.'
            }
        ]
    }
];

type RankItem = {
    rank: string;
    name: string;
    icon: SimpleIcon;
    viewBox?: string;
    tags: { label: string; tone: 'neutral' | 'violet' | 'emerald' | 'sky' }[];
    body: string;
    pros?: string[];
    cons?: string[];
};

const modelRankings: RankItem[] = [
    {
        rank: '01',
        name: 'Claude Opus 4.6',
        icon: siAnthropic,
        tags: [
            { label: 'reasoning', tone: 'violet' },
            { label: 'research', tone: 'sky' },
            { label: 'tech', tone: 'emerald' }
        ],
        body: 'Opus 4.6 is where I go for hardcore reasoning and technical research. It is the model I trust most when the task is messy, the architecture is unclear, or I want a strong thinking partner on difficult engineering tradeoffs.',
        pros: ['Excellent for deep technical reasoning and architecture work', 'Strong at research-heavy problem framing and critique'],
        cons: ['Slower and more expensive than faster editor-native options', 'Not the model I reach for first when the task is mostly visual iteration']
    },
    {
        rank: '02',
        name: 'Composer 2',
        icon: siCursor,
        tags: [
            { label: 'cursor only', tone: 'neutral' },
            { label: 'frontend', tone: 'violet' },
            { label: 'ui', tone: 'sky' },
            { label: 'fast iteration', tone: 'emerald' }
        ],
        body: 'Composer 2 is my workhorse in Cursor for UI and day-to-day implementation. For the price, speed, and capability, it is fantastic for layout, component iteration, visual cleanup, and keeping momentum in the repo.',
        pros: ['Outstanding for UI work and design-in-the-editor iteration', 'Excellent value-to-speed ratio for day-to-day product work'],
        cons: ['Tied to Cursor subscriptions and routing', 'Less suited than Opus for ambiguous deep research and hardest reasoning']
    },
    {
        rank: '03',
        name: 'GPT 5.4',
        icon: siOpenAI,
        viewBox: '0 0 16 16',
        tags: [
            { label: 'coding', tone: 'violet' },
            { label: 'modern tools', tone: 'emerald' },
            { label: 'up-to-date', tone: 'sky' }
        ],
        body: 'GPT 5.4 sits below Opus and Composer 2 for how I route most work, but it is still incredible for building modern tools and software. It has fast, reliable tool calling and will often one-shot a feature or feedback pass when I give it a strong prompt, and the more up-to-date training data shows up in newer APIs, libraries, and patterns.',
        pros: ['Fast, reliable tool calling with strong one-shot implementation ability', 'Very strong for building modern software against newer tooling'],
        cons: ['Opus and Composer 2 still win for my default reasoning and in-editor loops', 'I review output carefully on anything production-critical']
    },
    {
        rank: '04',
        name: 'Gemini 3.1 Pro',
        icon: siGooglegemini,
        tags: [
            { label: 'general assistant', tone: 'neutral' },
            { label: 'non-technical', tone: 'sky' },
            { label: 'multimodal', tone: 'violet' }
        ],
        body: 'I use Gemini 3.1 Pro in the Gemini app for everyday, non-technical conversations — travel, drafting, general chat — separate from my coding harnesses. It has the full breadth of Google behind it, which shows up in multimodal workflows and general knowledge.',
        pros: ['Strong multimodal and long-context workflows in the app', 'Great breadth for general chatting and non-technical assistant tasks'],
        cons: [
            'Not where I lean for agent harnesses or agentic coding workloads right now — tool calling is not strong enough compared to my top picks',
            'Not my primary coding agent and less integrated into my editor-centric loop'
        ]
    },
];

const harnessRankings: RankItem[] = [
    {
        rank: '01',
        name: 'Cursor',
        icon: siCursor,
        tags: [
            { label: 'coding', tone: 'violet' },
            { label: 'editor', tone: 'sky' },
            { label: 'composer', tone: 'neutral' },
            { label: 'cloud agents', tone: 'emerald' }
        ],
        body: 'My main harness and clear number one. Cursor wins for me because I can use all the models I care about, Composer usage is generous, cloud agents are a huge plus for real development work, and the overall UX, speed, and reliability are strong enough that it just works and just makes sense.',
        pros: [
            'Cloud agents are a major strength — I lean on them heavily for development work',
            'Best overall mix of model access, generous Composer, UX, speed, and reliability'
        ],
        cons: ['Platform churn still happens from time to time', 'Worth budgeting inference spend deliberately']
    },
    {
        rank: '02',
        name: 'OpenCode',
        icon: siTmux,
        tags: [
            { label: 'tui', tone: 'sky' },
            { label: 'terminal', tone: 'neutral' },
            { label: 'oss models', tone: 'emerald' }
        ],
        body: 'OpenCode is my number two when I want CLI or TUI workflows: open source, free models for experimentation, and sometimes light feature work in a keyboard-driven session with minimal chrome.',
        pros: [
            'My personal pick for terminal-first work when I am not in Cursor',
            'Great sandbox for OSS models without meter anxiety; fast for small scoped changes'
        ],
        cons: ['Not my first pick for heavy production refactors or deep debugging', 'Smaller ecosystem than mainstream IDEs']
    },
    {
        rank: '03',
        name: 'Claude',
        icon: siClaude,
        tags: [
            { label: 'planning & writing', tone: 'violet' },
            { label: 'app & api', tone: 'neutral' }
        ],
        body: 'Claude (app and API) for planning, writing, architecture reasoning, and long-form work outside the editor — not my primary coding harness.',
        pros: ['Flexible across tasks beyond code', 'Great for structured outputs and critique'],
        cons: ['Separate from repo context unless wired in manually']
    }
];

function tagClasses(tone: RankItem['tags'][number]['tone']) {
    switch (tone) {
        case 'violet':
            return tagViolet;
        case 'emerald':
            return tagEmerald;
        case 'sky':
            return tagSky;
        default:
            return tagNeutral;
    }
}
---

<BaseLayout title={title} {description} showHeader={false}>
    <article class="pt-16 sm:pt-24 pb-16 sm:pb-24">
        <header class="mb-12 sm:mb-16">
            <p class="font-mono text-xs text-muted mb-4 select-none">
                <span class="opacity-50">{'// '}</span>stack / tools / rankings
            </p>
            <h1 class="font-sans text-3xl sm:text-5xl font-medium tracking-tight text-main leading-tight">{title}</h1>
            <p class="mt-5 text-muted text-base sm:text-lg leading-relaxed max-w-2xl">
                what i use in production
            </p>
            <p
                class="mt-6 max-w-2xl border-l border-main/20 dark:border-main/25 pl-3.5 text-[0.7rem] sm:text-xs text-muted/75 dark:text-muted/70 leading-relaxed tracking-wide"
            >
                <span class="font-mono text-muted/90">Disclaimer.</span>{' '}
                Rankings here are my personal defaults and opinion — not universal truth or a live snapshot of the field. I still
                review anything that touches production; models speed exploration but do not replace ownership.
            </p>
        </header>

        <!-- State of AI -->
        <section class="mb-20 sm:mb-24" aria-labelledby="state-ai-heading">
            <div class="border-b border-main/20 pb-3.5 mb-6">
                <h2 id="state-ai-heading" class="font-sans text-3xl sm:text-4xl font-semibold tracking-tight text-main leading-tight">
                    State of AI
                </h2>
            </div>

            <div class="space-y-12">
                <div>
                    <h3 class="font-sans text-xl font-medium text-main mb-6">Models</h3>
                    <div class="space-y-5">
                        {
                            modelRankings.map((item) => (
                                <article class="border border-main/20 bg-muted/30 dark:bg-muted/20 overflow-hidden">
                                    <div class="flex flex-col sm:flex-row sm:items-stretch">
                                        <div class="font-mono text-xs text-muted tabular-nums px-4 py-3 sm:px-5 sm:py-4 border-b sm:border-b-0 sm:border-r border-main/15 bg-main/[0.03] shrink-0 sm:w-14 flex sm:items-start">
                                            {item.rank}
                                        </div>
                                        <div class="flex-1 px-4 py-4 sm:px-6 sm:py-5 min-w-0">
                                            <div class="flex flex-wrap items-start gap-4 gap-y-3">
                                                <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center border border-main/15 bg-main/5 text-main">
                                                    <SimpleIcon icon={item.icon} class="h-6 w-6" title={item.name} viewBox={item.viewBox} />
                                                </span>
                                                <div class="min-w-0 flex-1">
                                                    <h4 class="font-sans text-lg font-medium text-main leading-tight">
                                                        {item.name}
                                                    </h4>
                                                    <div class="mt-2 flex flex-wrap gap-1.5">
                                                        {item.tags.map((t) => (
                                                            <span class:list={[tagBase, tagClasses(t.tone)]}>{t.label}</span>
                                                        ))}
                                                    </div>
                                                    <p class="mt-3 text-sm text-muted leading-relaxed">{item.body}</p>
                                                    {item.pros && item.pros.length > 0 && (
                                                        <div class="mt-4 grid sm:grid-cols-2 gap-6 text-sm">
                                                            <div>
                                                                <p class="font-mono text-xs mb-1.5 text-main">
                                                                    <span class="text-emerald-700 dark:text-emerald-400">+</span>
                                                                    <span class="text-muted ml-1.5">Pros</span>
                                                                </p>
                                                                <ul class="space-y-1 text-muted list-disc pl-4 marker:text-main/40">
                                                                    {item.pros.map((p) => (
                                                                        <li>{p}</li>
                                                                    ))}
                                                                </ul>
                                                            </div>
                                                            {item.cons && item.cons.length > 0 && (
                                                                <div>
                                                                    <p class="font-mono text-xs mb-1.5 text-main">
                                                                        <span class="text-amber-800 dark:text-amber-300">−</span>
                                                                        <span class="text-muted ml-1.5">Cons</span>
                                                                    </p>
                                                                    <ul class="space-y-1 text-muted list-disc pl-4 marker:text-main/40">
                                                                        {item.cons.map((c) => (
                                                                            <li>{c}</li>
                                                                        ))}
                                                                    </ul>
                                                                </div>
                                                            )}
                                                        </div>
                                                    )}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            ))
                        }
                    </div>
                </div>

                <div>
                    <h3 class="font-sans text-xl font-medium text-main mb-6">Harnesses</h3>
                    <div class="space-y-5">
                        {
                            harnessRankings.map((item) => (
                                <article class="border border-main/20 bg-muted/30 dark:bg-muted/20 overflow-hidden">
                                    <div class="flex flex-col sm:flex-row sm:items-stretch">
                                        <div class="font-mono text-xs text-muted tabular-nums px-4 py-3 sm:px-5 sm:py-4 border-b sm:border-b-0 sm:border-r border-main/15 bg-main/[0.03] shrink-0 sm:w-14 flex sm:items-start">
                                            {item.rank}
                                        </div>
                                        <div class="flex-1 px-4 py-4 sm:px-6 sm:py-5 min-w-0">
                                            <div class="flex flex-wrap items-start gap-4 gap-y-3">
                                                <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center border border-main/15 bg-main/5 text-main">
                                                    <SimpleIcon icon={item.icon} class="h-6 w-6" title={item.name} />
                                                </span>
                                                <div class="min-w-0 flex-1">
                                                    <h4 class="font-sans text-lg font-medium text-main leading-tight">
                                                        {item.name}
                                                    </h4>
                                                    <div class="mt-2 flex flex-wrap gap-1.5">
                                                        {item.tags.map((t) => (
                                                            <span class:list={[tagBase, tagClasses(t.tone)]}>{t.label}</span>
                                                        ))}
                                                    </div>
                                                    <p class="mt-3 text-sm text-muted leading-relaxed">{item.body}</p>
                                                    {item.pros && item.pros.length > 0 && (
                                                        <div class="mt-4 grid sm:grid-cols-2 gap-6 text-sm">
                                                            <div>
                                                                <p class="font-mono text-xs mb-1.5 text-main">
                                                                    <span class="text-emerald-700 dark:text-emerald-400">+</span>
                                                                    <span class="text-muted ml-1.5">Pros</span>
                                                                </p>
                                                                <ul class="space-y-1 text-muted list-disc pl-4 marker:text-main/40">
                                                                    {item.pros.map((p) => (
                                                                        <li>{p}</li>
                                                                    ))}
                                                                </ul>
                                                            </div>
                                                            {item.cons && item.cons.length > 0 && (
                                                                <div>
                                                                    <p class="font-mono text-xs mb-1.5 text-main">
                                                                        <span class="text-amber-800 dark:text-amber-300">−</span>
                                                                        <span class="text-muted ml-1.5">Cons</span>
                                                                    </p>
                                                                    <ul class="space-y-1 text-muted list-disc pl-4 marker:text-main/40">
                                                                        {item.cons.map((c) => (
                                                                            <li>{c}</li>
                                                                        ))}
                                                                    </ul>
                                                                </div>
                                                            )}
                                                        </div>
                                                    )}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- Tech stack (languages, platforms, tooling) -->
        <section class="mb-8" aria-labelledby="state-software-heading">
            <div class="border-b border-main/20 pb-3.5 mb-6">
                <h2 id="state-software-heading" class="font-sans text-3xl sm:text-4xl font-semibold tracking-tight text-main leading-tight">
                    Tech stack
                </h2>
            </div>

            <div class="space-y-14">
                {
                    software.map((block) => (
                        <div class="space-y-4">
                            <div>
                                <h3 class="font-sans text-lg font-medium text-main">{block.title}</h3>
                                {block.intro && <p class="mt-1 text-sm text-muted leading-relaxed">{block.intro}</p>}
                            </div>
                            <ul class="space-y-4">
                                {block.rows.map((row) => (
                                    <li class="border border-main/20 bg-muted/40 dark:bg-muted/25 px-4 py-4 sm:px-5 sm:py-5">
                                        <div class="flex flex-wrap items-center gap-2 mb-3">
                                            {row.icon.map((ico) => (
                                                <span class="text-main/90 inline-flex h-8 w-8 items-center justify-center border border-main/15 bg-main/5">
                                                    <SimpleIcon icon={ico} class="h-4 w-4" title={ico.title} />
                                                </span>
                                            ))}
                                        </div>
                                        <p class="font-mono text-sm text-main leading-snug">{row.label}</p>
                                        {row.detail && <p class="mt-2 text-sm text-muted leading-relaxed">{row.detail}</p>}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </section>
    </article>
</BaseLayout>
