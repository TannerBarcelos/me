---
/**
 * `/projects/` redirects to the default lane; mirrors `/reads/` → shelf entry.
 */
import { DEFAULT_PROJECT_LANE, projectLanePath } from '../../data/project-lanes';

const fallbackHref = projectLanePath(DEFAULT_PROJECT_LANE);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="robots" content="noindex" />
        <meta http-equiv="refresh" content={`0;url=${fallbackHref}`} />
        <link rel="canonical" href={Astro.site ? new URL(fallbackHref, Astro.site).href : fallbackHref} />
        <title>Projects</title>
        <script is:inline define:vars={{ fallbackHref }}>
            (function () {
                try {
                    if (window.location.pathname + window.location.search + window.location.hash !== fallbackHref) {
                        window.location.replace(fallbackHref);
                    }
                } catch (e) {}
            })();
        </script>
    </head>
    <body>
        <p><a href={fallbackHref}>Continue to projects</a></p>
    </body>
</html>
