---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Pagination from '../../../../components/Pagination.astro';
import ReadPreview from '../../../../components/ReadPreview.astro';
import ReadsBrowseStrip from '../../../../components/ReadsBrowseStrip.astro';
import { READ_KINDS, type ReadKind } from '../../../../data/read-kinds';
import siteConfig from '../../../../data/site-config';
import { sortReadsByAddedDesc } from '../../../../utils/data-utils';
import { loadReadsBrowseData } from '../../../../utils/reads-browse';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const reads = (await getCollection('reads')).sort(sortReadsByAddedDesc);
    const pageSize = siteConfig.readsPerPage ?? 20;
    return READ_KINDS.flatMap((kind) => {
        const filtered = reads.filter((r) => r.data.kind === kind);
        return paginate(filtered, { pageSize, params: { kind } });
    });
}

type Props = { page: Page<CollectionEntry<'reads'>> };

const { page } = Astro.props;
const kind = Astro.params.kind as ReadKind;
const list = page.data;
const { topics } = await loadReadsBrowseData();
const kindLabel = kind.charAt(0).toUpperCase() + kind.slice(1);
---

<BaseLayout
    title={`Reads · ${kindLabel}`}
    description={`Favorite reads — filtered by ${kind}.`}
    showHeader={false}
>
    <div class="pt-16 sm:pt-24 pb-24 sm:pb-32">
        <p class="font-mono text-xs text-muted mb-4 select-none">
            <span class="opacity-50">{'// '}</span>reads / {kind}
        </p>
        <h1 class="font-sans text-3xl sm:text-4xl font-medium tracking-tight text-main mb-3 capitalize">{kind}</h1>
        <p class="text-muted text-sm sm:text-base leading-relaxed max-w-2xl mb-10 sm:mb-12">
            Entries tagged as <span class="text-main/90">{kindLabel}</span> in the catalog. Use All to see everything
            across formats.
        </p>

        <ReadsBrowseStrip topics={topics} active={{ type: 'kind', kind }} />

        <div>
            {list.length > 0 ? (
                list.map((read) => <ReadPreview read={read} />)
            ) : (
                <p class="text-muted text-sm py-8">Nothing in this format yet.</p>
            )}
        </div>

        <Pagination page={page} class="mt-16 sm:mt-24" />
    </div>
</BaseLayout>
