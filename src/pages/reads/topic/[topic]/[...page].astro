---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Pagination from '../../../../components/Pagination.astro';
import ReadPreview from '../../../../components/ReadPreview.astro';
import ReadsBrowseStrip from '../../../../components/ReadsBrowseStrip.astro';
import siteConfig from '../../../../data/site-config';
import { sortReadsByAddedDesc } from '../../../../utils/data-utils';
import { loadReadsBrowseData } from '../../../../utils/reads-browse';
import { slugifyTopic } from '../../../../utils/slugify';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const reads = (await getCollection('reads')).sort(sortReadsByAddedDesc);
    const { topics } = await loadReadsBrowseData();
    const pageSize = siteConfig.readsPerPage ?? 20;

    return topics.flatMap(({ slug }) => {
        const filtered = reads.filter((r) => r.data.topics.some((t) => slugifyTopic(t) === slug));
        return paginate(filtered, { pageSize, params: { topic: slug } });
    });
}

type Props = { page: Page<CollectionEntry<'reads'>> };

const { page } = Astro.props;
const topic = Astro.params.topic!;
const list = page.data;
const { topics } = await loadReadsBrowseData();
const topicMeta = topics.find((t) => t.slug === topic);
const topicLabel = topicMeta?.label ?? topic;
---

<BaseLayout
    title={`Reads · ${topicLabel}`}
    description={`Favorite reads tagged “${topicLabel}”.`}
    showHeader={false}
>
    <div class="pt-16 sm:pt-24 pb-24 sm:pb-32">
        <p class="font-mono text-xs text-muted mb-4 select-none">
            <span class="opacity-50">{'// '}</span>reads / topic / {topic}
        </p>
        <h1 class="font-sans text-3xl sm:text-4xl font-medium tracking-tight text-main mb-3">{topicLabel}</h1>
        <p class="text-muted text-sm sm:text-base leading-relaxed max-w-2xl mb-10 sm:mb-12">
            Shelved under this topic. Combine with format filters from the strip above when you need a narrower slice.
        </p>

        <ReadsBrowseStrip topics={topics} active={{ type: 'topic', slug: topic }} />

        <div>
            {list.length > 0 ? (
                list.map((read) => <ReadPreview read={read} />)
            ) : (
                <p class="text-muted text-sm py-8">No entries for this topic.</p>
            )}
        </div>

        <Pagination page={page} class="mt-16 sm:mt-24" />
    </div>
</BaseLayout>
