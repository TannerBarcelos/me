---
/**
 * Legacy per-read URLs: redirect to the canonical external link (or back to the shelf).
 * The bookshelf lists link directly to `url`; this keeps old bookmarks working.
 */
import { getCollection } from 'astro:content';
import { readsShelfPath } from '../../utils/reads-links';

export async function getStaticPaths() {
    const reads = await getCollection('reads');
    return reads.map((read) => ({
        params: { slug: read.slug },
        props: { read }
    }));
}

const { read } = Astro.props;
const dest = read.data.url ?? readsShelfPath(read.data.shelf);
const layoutTitle = read.data.seo?.title ?? read.data.title;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="robots" content="noindex" />
        <meta http-equiv="refresh" content={`0;url=${dest}`} />
        <title>{layoutTitle}</title>
        <script is:inline define:vars={{ dest }}>
            try {
                window.location.replace(dest);
            } catch (e) {}
        </script>
    </head>
    <body>
        <p>
            <a href={dest}>{read.data.url ? 'Continue to source' : 'Back to bookshelf'}</a>
        </p>
    </body>
</html>
