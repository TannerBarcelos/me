---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '../../components/Pagination.astro';
import ReadPreview from '../../components/ReadPreview.astro';
import ReadsBrowseStrip from '../../components/ReadsBrowseStrip.astro';
import siteConfig from '../../data/site-config';
import { sortReadsByAddedDesc } from '../../utils/data-utils';
import { loadReadsBrowseData } from '../../utils/reads-browse';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const reads = (await getCollection('reads')).sort(sortReadsByAddedDesc);
    const pageSize = siteConfig.readsPerPage ?? 20;
    return paginate(reads, { pageSize });
}

type Props = { page: Page<CollectionEntry<'reads'>> };

const { page } = Astro.props;
const list = page.data;
const { topics } = await loadReadsBrowseData();
---

<BaseLayout
    title="Reads"
    description="Books, papers, and articles I recommend — separate from the blog, built to grow."
    showHeader={false}
>
    <div class="pt-16 sm:pt-24 pb-24 sm:pb-32">
        <p class="font-mono text-xs text-muted mb-4 select-none">
            <span class="opacity-50">{'// '}</span>reads
        </p>
        <h1 class="font-sans text-3xl sm:text-4xl font-medium tracking-tight text-main mb-3">
            Favorite reads
        </h1>
        <p class="text-muted text-sm sm:text-base leading-relaxed max-w-2xl mb-2">
            A running list of work that shaped how I think about engineering, systems, and craft — curated here so it
            can scale as the shelf grows. This is not my blog; it is reference material I actually return to.
        </p>
        <p class="font-mono text-xs text-muted/80 mb-10 sm:mb-12">
            Tip: filter by format or topic, or open an entry for notes and outbound links.
        </p>

        <ReadsBrowseStrip topics={topics} active={{ type: 'all' }} />

        <div>
            {list.map((read) => <ReadPreview read={read} />)}
        </div>

        <Pagination page={page} class="mt-16 sm:mt-24" />
    </div>
</BaseLayout>
